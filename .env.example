# ============================================================
# MSA 프로젝트 루트 — `cp .env.example .env` 후 값 채우기
# 공개 저장소에는 .env 를 커밋하지 마세요. 운영 값은 GitHub Secrets → CI/CD 또는 서버에만 둡니다.
#
# 로컬 전체 동작: 프로젝트 루트에서 `docker compose up -d --build` (또는 메모리 부족 시 핵심 서비스만).
# 프론트만 `npm run dev` 할 때는 게이트웨이가 8085에서 떠 있어야 하며, apiBase.js 가 개발 모드에서
# http://127.0.0.1:8085 를 기본으로 씁니다. 백오피스 프록시는 frontend/nextjs-app/.env.local 에
# GATEWAY_INTERNAL_URL=http://localhost:8085 권장.
# ============================================================

# ----- GitHub Actions 배포 빌드 (Repository → Settings → Secrets and variables → Actions → Variables) -----
# PUBLIC_SITE_URL=https://실제도메인
# PUBLIC_API_URL=https://실제도메인
# (선택) PUBLIC_MONITOR_URL=, PUBLIC_CHATBOT_URL= (비우면 API_URL 기준 /chat 로 추론)
# 서버 .env 에는 CORS_ALLOWED_ORIGINS·FRONTEND_URL·GHCR DOCKER_IMAGE_PREFIX 등 운영 값 반영

# ----- Docker 이미지 -----
# 로컬에서 빌드해 쓸 때(기본): 로컬 전용 프리픽스 — compose 가 로컬에서 이미지를 빌드해 사용합니다.
DOCKER_IMAGE_PREFIX=local/msa
IMAGE_TAG=latest
# 운영 서버 .env 에서만 아래처럼 GHCR 로 바꾸세요(저장소 경로는 반드시 소문자).
# DOCKER_IMAGE_PREFIX=ghcr.io/github-사용자명/저장소명
# IMAGE_TAG 는 CI 배포 시 커밋 SHA 로 덮어씌워집니다.

# Mac(ARM)에서 Lightsail(amd64)용 이미지를 만들 때(선택):
# export DOCKER_DEFAULT_PLATFORM=linux/amd64

# ----- PostgreSQL (모든 DB 동일 비밀번호 사용 시; 기존 서버 호환: 예전 값 유지 가능) -----
POSTGRES_PASSWORD=change-me-strong-password

DB_AUTH_NAME=mk_auth
DB_USER_NAME=mk_user
DB_POST_NAME=mk_post
DB_SEARCH_NAME=mk_search

# ----- JWT (Auth·Gateway·User·Post·SMTP 공통, 반드시 긴 랜덤 문자열) -----
JWT_SECRET=change-me-min-32-chars-base64-or-long-random-string

# ----- Gateway CORS (쉼표 구분, 브라우저에서 허용할 Origin 목록) -----
# 로컬: http://localhost:3000,http://localhost:4000
# 운영 예: https://yourdomain.com,https://www.yourdomain.com,https://dev.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000,http://127.0.0.1:3000,http://127.0.0.1:4000

# ----- Auth 서비스 (쿠키·OAuth 리다이렉트) -----
FRONTEND_URL=http://localhost:3000
# 운영 예: .yourdomain.com (앞에 점)
COOKIE_DOMAIN=
# OAuth2 승인 후 IdP가 브라우저를 되돌릴 URL(게이트웨이 경로 /auth/login/oauth2/code/*).
# 로컬: 프론트 3000·API 8085 분리 시 반드시 게이트웨이. Google/Kakao/GitHub 콘솔에도 동일 URI 등록.
OAUTH2_REDIRECT_BASE=http://localhost:8085
# 운영(단일 도메인 Nginx가 /auth 를 API 로 넘기면): https://yourdomain.com

OAUTH2_GOOGLE_CLIENT_ID=
OAUTH2_GOOGLE_CLIENT_SECRET=
OAUTH2_KAKAO_CLIENT_ID=
OAUTH2_KAKAO_CLIENT_SECRET=
OAUTH2_GITHUB_CLIENT_ID=
OAUTH2_GITHUB_CLIENT_SECRET=

# 부트스트랩 관리자 (선택)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# ----- 메일 (SMTP) -----
MAIL_USERNAME=
MAIL_PASSWORD=

# ----- AI 챗봇 -----
GROQ_API_KEY=

# ----- Next.js 빌드 타임 (Docker build args / .env.local) -----
# 로컬에서 docker compose 할 때 NEXT_PUBLIC_* 가 운영(https://실제도메인)이면 브라우저가 원격 API로 붙어 로그인 실패함.
# apiBase.js 가 localhost/127.0.0.1 접속 시 자동으로 호스트:8085 로 보정하지만, 로컬 전용 .env 분리를 권장.
# 프론트만 npm run dev 할 때: frontend/nextjs-app/.env.example → .env.local 복사(백오피스 프록시용 GATEWAY_INTERNAL_URL)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_MONITOR_URL=
NEXT_PUBLIC_API_URL=http://localhost:8085
NEXT_PUBLIC_AUTH_API_URL=http://localhost:8085
NEXT_PUBLIC_USER_API_URL=http://localhost:8085
NEXT_PUBLIC_POST_API_URL=http://localhost:8085
NEXT_PUBLIC_CHATBOT_API_URL=http://localhost:8085/chat

# ----- 로그 레벨 (Spring: LOGGING_LEVEL_ROOT=ERROR 등) -----
LOGGING_LEVEL_ROOT=INFO

# ----- Fluent Bit → 원격 Loki (메인 compose 의 fluent-bit 서비스) -----
LOKI_HOST=observe.yourdomain.com
LOKI_PORT=443

# ----- 모니터링 스택 (monitoring/docker-compose.monitoring.yml) -----
GRAFANA_ADMIN_PASSWORD=change-me
GF_SERVER_ROOT_URL=http://localhost:3001

# ----- 업로드 경로 (Post 서비스, 호스트 마운트 시) -----
POST_COVER_UPLOAD_DIR=/app/data/post-covers
