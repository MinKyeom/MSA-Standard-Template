# Alpine(musl) + arm64 에서 Next.js SWC 바이너리 오류(__res_init)가 나므로 glibc 기반 사용
FROM node:18-bookworm-slim
WORKDIR /app

ENV NEXT_TELEMETRY_DISABLED=1

# Build-time env (Next.js bakes NEXT_PUBLIC_* into the bundle)
ARG NEXT_PUBLIC_SITE_URL
ARG NEXT_PUBLIC_MONITOR_URL
ARG NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_AUTH_API_URL
ARG NEXT_PUBLIC_USER_API_URL
ARG NEXT_PUBLIC_POST_API_URL
ARG NEXT_PUBLIC_CHATBOT_API_URL

ENV NEXT_PUBLIC_SITE_URL=$NEXT_PUBLIC_SITE_URL
ENV NEXT_PUBLIC_MONITOR_URL=$NEXT_PUBLIC_MONITOR_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_AUTH_API_URL=$NEXT_PUBLIC_AUTH_API_URL
ENV NEXT_PUBLIC_USER_API_URL=$NEXT_PUBLIC_USER_API_URL
ENV NEXT_PUBLIC_POST_API_URL=$NEXT_PUBLIC_POST_API_URL
ENV NEXT_PUBLIC_CHATBOT_API_URL=$NEXT_PUBLIC_CHATBOT_API_URL

COPY package.json package-lock.json ./
RUN --mount=type=cache,target=/root/.npm \
    npm ci

COPY . .

RUN npm run build

EXPOSE 3000
CMD ["npm", "start"]