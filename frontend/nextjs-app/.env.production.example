# Docker 빌드 시 docker-compose 의 build args 가 우선합니다.
# 로컬 `next build` 만 할 때는 이 파일을 .env.production 으로 복사한 뒤 수정하세요.
# cp .env.production.example .env.production
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_MONITOR_URL=
NEXT_PUBLIC_API_URL=http://localhost:8085
NEXT_PUBLIC_AUTH_API_URL=http://localhost:8085
NEXT_PUBLIC_USER_API_URL=http://localhost:8085
NEXT_PUBLIC_POST_API_URL=http://localhost:8085
NEXT_PUBLIC_CHATBOT_API_URL=http://localhost:8085/chat
