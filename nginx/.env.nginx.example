# cp nginx/.env.nginx.example nginx/.env.nginx 후 값 수정
# ./scripts/render-nginx.sh

NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# server_name (공백 구분) — 본인 도메인으로 변경
PRIMARY_SERVER_NAMES="example.com www.example.com"

SSL_CERT_PATH=/etc/letsencrypt/live/example.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/example.com/privkey.pem

# 호스트 Nginx → Docker 게이트웨이·프론트 published 포트
UPSTREAM_GATEWAY=127.0.0.1:8085
UPSTREAM_FRONTEND=127.0.0.1:3000

# /metrics/node 허용 IP (Prometheus 등, 없으면 127.0.0.1)
METRICS_ALLOW_IP=127.0.0.1

# 개발 서버 블록 (미사용 시 더미 값 유지 — envsubst 가 모든 플레이스홀더 치환)
DEV_DOMAIN=dev.example.com
DEV_SSL_CERT=/etc/letsencrypt/live/dev.example.com/fullchain.pem
DEV_SSL_KEY=/etc/letsencrypt/live/dev.example.com/privkey.pem
DEV_UPSTREAM_FRONTEND=127.0.0.1:4000
DEV_UPSTREAM_GATEWAY=127.0.0.1:9085
