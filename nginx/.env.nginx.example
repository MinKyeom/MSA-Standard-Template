# cp nginx/.env.nginx.example nginx/.env.nginx 후 값 수정
# ./scripts/render-nginx.sh

NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# server_name 에 쓸 호스트들 (공백 구분)
PRIMARY_SERVER_NAMES="minkowskim.com www.minkowskim.com"

SSL_CERT_PATH=/etc/letsencrypt/live/minkowskim.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/minkowskim.com/privkey.pem

# 호스트 Nginx → Docker published 포트로 프록시 (일반적으로 127.0.0.1)
UPSTREAM_GATEWAY=127.0.0.1:8085
UPSTREAM_FRONTEND=127.0.0.1:3000

# /metrics/node 허용 IP (observe Prometheus 등)
METRICS_ALLOW_IP=3.36.84.83

# 개발 서버 블록 (미사용 시에도 더미 값 필요 — envsubst 가 모든 플레이스홀더 치환)
DEV_DOMAIN=dev.minkowskim.com
DEV_SSL_CERT=/etc/letsencrypt/live/dev.minkowskim.com/fullchain.pem
DEV_SSL_KEY=/etc/letsencrypt/live/dev.minkowskim.com/privkey.pem
DEV_UPSTREAM_FRONTEND=127.0.0.1:4000
DEV_UPSTREAM_GATEWAY=127.0.0.1:9085
