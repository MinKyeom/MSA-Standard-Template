# ----- 환경 변수·키 (예시 파일 *.example 만 저장소에 둠) -----
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
.env.build
.env.deploy.tmp
*.pem
*.pem.pub
*.p12
*.pfx

nginx/.env.nginx

# ----- Docker Compose 로컬 전용(공식 관례: 덮어쓰기만) -----
docker-compose.override.yml

# ----- 운영·로컬 데이터( DB 볼륨, 업로드 등 ) — 저장소 루트만 (src/data 등 소스 JSON 은 커밋) -----
/data/

# ----- 로그·임시 -----
*.log
tmp/
temp/
*.tmp
*.temp
*.pid
*.seed
*.pid.lock

# ----- OS -----
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

